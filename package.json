{
  "name": "contrib",
  "version": "1.0.0",
  "main": "dist/main.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "swc src -d dist --copy-files --strip-leading-paths",
    "build:watch": "swc src -d dist --watch --copy-files --strip-leading-paths",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist && rm report.*",
    "report:pdf": "npm run build && node dist/main.js | asciidoctor-pdf -o report.pdf -",
    "report:html": "npm run build && node dist/main.js | asciidoctor -o report.html -",
    "report:asciidoc": "npm run build && node dist/main.js > report.adoc"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.1",
    "eta": "^4.0.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.19",
    "@types/node": "^24.5.2",
    "chokidar": "^4.0.3",
    "prettier": "3.6.2",
    "typescript": "^5.9.2"
  }
}
